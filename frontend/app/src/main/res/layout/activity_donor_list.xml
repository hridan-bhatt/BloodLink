                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="MP"
                        android:textColor="@color/blood_red"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:background="@drawable/bg_avatar"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Meera Patel"
                        android:textColor="@color/black_text"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="@id/tvAvatar2"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar2"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron2"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="📍 Surat, Gujarat"
                        android:textColor="@color/gray_text"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="2dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tvAvatar2"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar2"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron2"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="🩸 O+"
                        android:textColor="@color/blood_red"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginTop="2dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tvAvatar2"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar2"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron2"/>

                    <TextView
                        android:id="@+id/tvChevron2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/gray_text"
                        android:textSize="20sp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 3 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDonor3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider_gray"
                app:strokeWidth="1.5dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvAvatar3"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="RS"
                        android:textColor="@color/blood_red"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:background="@drawable/bg_avatar"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Rahul Shah"
                        android:textColor="@color/black_text"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="@id/tvAvatar3"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar3"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron3"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="📍 Vadodara, Gujarat"
                        android:textColor="@color/gray_text"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="2dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tvAvatar3"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar3"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron3"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="🩸 A+"
                        android:textColor="@color/blood_red"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginTop="2dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tvAvatar3"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar3"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron3"/>

                    <TextView
                        android:id="@+id/tvChevron3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/gray_text"
                        android:textSize="20sp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 4 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDonor4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider_gray"
                app:strokeWidth="1.5dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvAvatar4"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="PD"
                        android:textColor="@color/blood_red"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:background="@drawable/bg_avatar"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Priya Desai"
                        android:textColor="@color/black_text"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="@id/tvAvatar4"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar4"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron4"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="📍 Rajkot, Gujarat"
                        android:textColor="@color/gray_text"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="2dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tvAvatar4"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar4"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron4"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="🩸 AB+"
                        android:textColor="@color/blood_red"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginTop="2dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tvAvatar4"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar4"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron4"/>

                    <TextView
                        android:id="@+id/tvChevron4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/gray_text"
                        android:textSize="20sp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 5 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDonor5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider_gray"
                app:strokeWidth="1.5dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvAvatar5"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="NK"
                        android:textColor="@color/blood_red"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:background="@drawable/bg_avatar"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Neel Kothari"
                        android:textColor="@color/black_text"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="@id/tvAvatar5"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar5"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron5"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="📍 Gandhinagar, Gujarat"
                        android:textColor="@color/gray_text"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="2dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tvAvatar5"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar5"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron5"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="🩸 O-"
                        android:textColor="@color/blood_red"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginTop="2dp"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tvAvatar5"
                        app:layout_constraintStart_toEndOf="@id/tvAvatar5"
                        app:layout_constraintEnd_toStartOf="@id/tvChevron5"/>

                    <TextView
                        android:id="@+id/tvChevron5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/gray_text"
                        android:textSize="20sp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
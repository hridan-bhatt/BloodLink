<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/ecgLine"
            android:layout_width="280dp"
            android:layout_height="50dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/ecg_line"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvBloodLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bebas_neue"
            android:letterSpacing="0.15"
            android:text="BLOODLINK"
            android:textSize="36sp"
            android:textColor="@color/black_text"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/ecgLine"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bebas_neue"
            android:letterSpacing="0.2"
            android:text="REQUEST DETAILS"
            android:textColor="@color/gray_text"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvBloodLink"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="@color/blood_red"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvTagline"
            app:layout_constraintStart_toStartOf="parent"/>

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


        <TextView
            android:id="@+id/tvBloodGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="B+"
            android:textColor="@color/blood_red"
            android:textSize="52sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvUrgency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CRITICAL"
            android:textColor="@color/white_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_semibold"
            android:background="@drawable/bg_role_badge"
            android:paddingHorizontal="14dp"
            android:paddingVertical="4dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvBloodGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/divider2"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvUrgency"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REQUEST INFO"
            android:textColor="@color/blood_red"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/divider2"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvHospitalLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hospital"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvDetails"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvHospital"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Civil Hospital"
            android:textColor="@color/black_text"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvHospitalLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvHospitalLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/dividerHospital"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvHospitalLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvCityLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="City"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dividerHospital"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvCity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ahmedabad"
            android:textColor="@color/black_text"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvCityLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvCityLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/dividerCity"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvCityLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvUnitsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Units Required"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dividerCity"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvUnits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2"
            android:textColor="@color/black_text"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvUnitsLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvUnitsLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/dividerUnits"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvUnitsLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dividerUnits"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Open"
            android:textColor="@color/blood_red"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvStatusLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvStatusLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnRespond"
            app:cornerRadius="12dp"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="Respond to Request"
            android:textColor="@color/white_text"
            android:backgroundTint="@color/blood_red"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="15sp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/tvStatusLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ecgLine"
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:layout_marginTop="40dp"
                android:src="@drawable/ecg_line"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvBloodLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bebas_neue"
                android:letterSpacing="0.15"
                android:text="BLOODLINK"
                android:textSize="36sp"
                android:textColor="@color/black_text"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/ecgLine"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bebas_neue"
                android:letterSpacing="0.2"
                android:text="RECIPIENT DASHBOARD"
                android:textColor="@color/gray_text"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvBloodLink"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back,"
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="28dp"
                android:layout_marginStart="24dp"
                app:layout_constraintTop_toBottomOf="@id/tvTagline"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riya Sharma"
                android:textColor="@color/black_text"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginStart="24dp"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/tvGreeting"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvUserMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="O+ · Ahmedabad"
                android:textColor="@color/blood_red"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginStart="24dp"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/tvUserName"
                app:layout_constraintStart_toStartOf="parent"/>

            <ImageView
                android:id="@+id/ivBell"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_bell"
                android:layout_marginEnd="24dp"
                app:tint="@color/blood_red"
                app:layout_constraintTop_toTopOf="@id/tvGreeting"
                app:layout_constraintBottom_toBottomOf="@id/tvUserMeta"
                app:layout_constraintEnd_toEndOf="parent"/>

            <View
                android:id="@+id/divider"
                android:layout_width="0dp"
                android:layout_height="0.5dp"
                android:background="@color/divider_gray"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/tvUserMeta"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvActiveLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE REQUESTS"
                android:textColor="@color/blood_red"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginStart="24dp"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/divider"
                app:layout_constraintStart_toStartOf="parent"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActiveRequest"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_red"
                app:strokeWidth="1.5dp"
                app:layout_constraintTop_toBottomOf="@id/tvActiveLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvActiveBloodGroup"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="O+"
                            android:textColor="@color/blood_red"
                            android:textSize="28sp"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:id="@+id/tvActiveStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Open"
                            android:textColor="@color/blood_red"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_semibold"
                            android:background="@drawable/bg_status_badge"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvActiveHospital"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Civil Hospital, Ahmedabad · 2 units"
                        android:textColor="@color/gray_text"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:id="@+id/tvRespondents"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 donors have responded"
                        android:textColor="@color/black_text"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <Button
                android:id="@+id/btnCreateRequest"
                app:cornerRadius="12dp"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="Create new request"
                android:textColor="@color/white_text"
                android:backgroundTint="@color/blood_red"
                android:fontFamily="@font/poppins_semibold"
                android:textSize="15sp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/cardActiveRequest"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>


            <TextView
                android:id="@+id/tvDonorsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEARBY DONORS"
                android:textColor="@color/blood_red"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginStart="24dp"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/btnCreateRequest"
                app:layout_constraintStart_toStartOf="parent"/>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDonor1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:layout_constraintTop_toBottomOf="@id/tvDonorsLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rahul Patel"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="O+ • Ahmedabad"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>




    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/background_light"
        app:menu="@menu/recipient_bottom_nav"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/ecgLine"
            android:layout_width="280dp"
            android:layout_height="50dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/ecg_line"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvBloodLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bebas_neue"
            android:letterSpacing="0.15"
            android:text="BLOODLINK"
            android:textSize="36sp"
            android:textColor="@color/black_text"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/ecgLine"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bebas_neue"
            android:letterSpacing="0.2"
            android:text="DONOR DETAILS"
            android:textColor="@color/gray_text"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvBloodLink"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="@color/blood_red"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvTagline"
            app:layout_constraintStart_toStartOf="parent"/>

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Avatar -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="AK"
            android:textColor="@color/blood_red"
            android:textSize="24sp"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:background="@drawable/bg_avatar"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvDonorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Arjun Kumar"
            android:textColor="@color/black_text"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvBloodGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="B+"
            android:textColor="@color/white_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_semibold"
            android:background="@drawable/bg_role_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="3dp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvDonorName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/divider2"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvBloodGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvInfoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DONOR INFO"
            android:textColor="@color/blood_red"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/divider2"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Info rows -->
        <TextView
            android:id="@+id/tvCityLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="City"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvInfoLabel"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvCity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ahmedabad"
            android:textColor="@color/black_text"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvCityLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvCityLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/dividerCity"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvCityLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvStateLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="State"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dividerCity"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gujarat"
            android:textColor="@color/black_text"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvStateLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvStateLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/dividerState"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvStateLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvPhoneLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dividerState"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9876543210"
            android:textColor="@color/black_text"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvPhoneLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvPhoneLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnContact"
            app:cornerRadius="12dp"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="Contact Donor"
            android:textColor="@color/white_text"
            android:backgroundTint="@color/blood_red"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="15sp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/tvPhoneLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
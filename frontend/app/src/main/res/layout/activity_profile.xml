<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/ecgLine"
            android:layout_width="280dp"
            android:layout_height="50dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/ecg_line"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvBloodLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bebas_neue"
            android:letterSpacing="0.15"
            android:text="BLOODLINK"
            android:textSize="36sp"
            android:textColor="@color/black_text"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/ecgLine"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bebas_neue"
            android:letterSpacing="0.2"
            android:text="YOUR PROFILE"
            android:textColor="@color/gray_text"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvBloodLink"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Avatar -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="HB"
            android:textColor="@color/blood_red"
            android:textSize="24sp"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:background="@drawable/bg_avatar"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvTagline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hridan Bhatt"
            android:textColor="@color/black_text"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Donor"
            android:textColor="@color/white_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_semibold"
            android:background="@drawable/bg_role_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="3dp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvUserName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvRole"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvInfoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERSONAL INFO"
            android:textColor="@color/blood_red"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Info rows -->
        <TextView
            android:id="@+id/tvEmailLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvInfoLabel"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="hridan@gmail.com"
            android:textColor="@color/black_text"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvEmailLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvEmailLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/dividerEmail"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvEmailLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvPhoneLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dividerEmail"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9876543210"
            android:textColor="@color/black_text"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvPhoneLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvPhoneLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/dividerPhone"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvPhoneLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvBloodLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Blood Group"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dividerPhone"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvBloodGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="B+"
            android:textColor="@color/blood_red"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvBloodLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvBloodLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/dividerBlood"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvBloodLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvCityLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="City"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dividerBlood"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvCity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vadodara"
            android:textColor="@color/black_text"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvCityLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvCityLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/dividerCity"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/divider_gray"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvCityLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvStateLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="State"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/dividerCity"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gujarat"
            android:textColor="@color/black_text"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/tvStateLabel"
            app:layout_constraintBottom_toBottomOf="@id/tvStateLabel"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Buttons -->
        <Button
            android:id="@+id/btnEditProfile"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="12dp"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="Edit Profile"
            android:textColor="@color/blood_red"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="15sp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:strokeColor="@color/border_red"
            app:layout_constraintTop_toBottomOf="@id/tvStateLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnLogout"
            app:cornerRadius="12dp"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="Log Out"
            android:textColor="@color/white_text"
            android:backgroundTint="@color/blood_red"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="15sp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnEditProfile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>



    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/background_light"
        app:menu="@menu/donor_bottom_nav"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
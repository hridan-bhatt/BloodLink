<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDonor"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider_gray"
    app:strokeWidth="1.5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textColor="@color/blood_red"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_semibold"
            android:background="@drawable/bg_avatar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvDonorName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/black_text"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="@id/tvAvatar"
            app:layout_constraintStart_toEndOf="@id/tvAvatar"
            app:layout_constraintEnd_toStartOf="@id/tvChevron"/>

        <TextView
            android:id="@+id/tvDonorCity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginTop="2dp"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvDonorName"
            app:layout_constraintStart_toEndOf="@id/tvAvatar"
            app:layout_constraintEnd_toStartOf="@id/tvChevron"/>

        <TextView
            android:id="@+id/tvDonorBloodGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/blood_red"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginTop="2dp"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvDonorCity"
            app:layout_constraintStart_toEndOf="@id/tvAvatar"
            app:layout_constraintEnd_toStartOf="@id/tvChevron"/>

        <TextView
            android:id="@+id/tvChevron"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="@color/gray_text"
            android:textSize="20sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
